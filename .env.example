# PiscesER1 Marine Support Bot Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# ServiceDesk Plus Configuration
# =============================================================================
SDP_DEPLOYMENT=on_premise
SDP_BASE_URL=http://122.165.246.80:8081/api/v3
SDP_API_KEY=BC086EDC-C7F1-484F-9B29-45E2F1A69CA8
SDP_TECHNICIAN_EMAIL=
SDP_SITE_ID=
SDP_GROUP_ID=
SDP_TECHNICIAN_ID=

# =============================================================================
# Google Gemini Configuration
# =============================================================================
# Get your API key from: https://aistudio.google.com/apikey
# Free tier: gemini-2.5-flash-lite (1,500 req/day, 30 RPM) or gemini-2.5-flash (1,500 req/day, 15 RPM)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.7

# =============================================================================
# Application Configuration
# =============================================================================
SUPPORT_EMAIL=support@pisceser1marine.com

# =============================================================================
# Email Configuration for Escalations
# =============================================================================
# For local mail servers (Exchange, Postfix), use:
#   SMTP_SERVER=mail.yourdomain.local or localhost
#   SMTP_PORT=25
#   SMTP_USERNAME= (leave empty)
#   SMTP_PASSWORD= (leave empty)
#
# For Gmail/Cloud SMTP, use:
#   SMTP_SERVER=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=your-email@gmail.com
#   SMTP_PASSWORD=your-app-password

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME= 
SMTP_PASSWORD= 

# =============================================================================
# Escalation Contacts
# =============================================================================
EMERGENCY_CONTACT=
SENIOR_MANAGER=
TECHNICAL_LEAD=

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=pisces_support_bot.log

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=sqlite:///pisces_support_bot.db

# =============================================================================
# Scheduling Configuration
# =============================================================================
CHECK_INTERVAL_MINUTES=5
MAX_TICKETS_PER_RUN=10

